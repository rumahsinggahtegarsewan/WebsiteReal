# .env.example — Rumah Singgah Tegar Sewan
#
# This is a STATIC site. It has no backend, no database, and no server-side
# secrets. This file documents the one value that must be set before launch.
#
# HOW TO USE
# ----------
# 1. Copy this file to .env  (already excluded by .gitignore — never commit .env)
# 2. Fill in the real value below
# 3. Paste it into the HTML <head> of every page as shown in the comment
#
# .env is only for your own reference during setup.
# The GA4 ID goes directly in the HTML <head> — it is a PUBLIC identifier
# by Google's design and is safe to commit in HTML files.

# Google Analytics 4 Measurement ID
# Format: G-XXXXXXXXXX
# Where to put it: replace [GA4_MEASUREMENT_ID] in every page's <head>:
#
#   <script async src="https://www.googletagmanager.com/gtag/js?id=[GA4_MEASUREMENT_ID]"></script>
#   <script>
#     window.dataLayer = window.dataLayer || [];
#     function gtag(){dataLayer.push(arguments);}
#     gtag('js', new Date());
#     gtag('config', '[GA4_MEASUREMENT_ID]');
#   </script>
#
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------
# Nothing else belongs here.
# This site intentionally has no API keys, no OAuth tokens, no database
# connection strings, and no service accounts. If you find yourself adding
# one, re-read the architecture rules in CLAUDE.md first.
# -----------------------------------------------------------------------
